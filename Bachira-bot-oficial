# 🧠 CÓDIGO PRINCIPAL CON TODAS LAS FUNCIONES
cat > index.js << 'EOF'
require('dotenv').config();
const { Client, LocalAuth, MessageMedia } = require('whatsapp-web.js');
const qrcode = require('qrcode-terminal');
const axios = require('axios');
const fs = require('fs-extra');

const bot = new Client({
    authStrategy: new LocalAuth(),
    puppeteer: { headless: true, args: ['--no-sandbox','--disable-setuid-sandbox'] }
});

bot.on('qr', codigo => {
    console.log('\n📲 ESCANEA EL QR | BACHIRA ACTIVO 🟡⚡\n');
    qrcode.generate(codigo, { small: true });
});

bot.on('ready', () => {
    console.log('\n✅ BACHIRA BOT 100% FUNCIONAL');
    console.log('👤 Creado por: Benjare');
    console.log('🌎 País: Argentina 🇦🇷\n');
});

const MENU = `🟡⚡ **BACHIRA - BOT OFICIAL** ⚽

¡Hola! Soy **Bachira**, traigo magia y potencia desde **Argentina**.
Creado totalmente por **Benjare**, con todo lo que necesitás.

> ❝ *La locura es lo que hace que el talento brille.* ❞

🤖 **INTELIGENCIA • CHAT GPT**
!ia [pregunta] → Te respondo cualquier duda
!gpt [texto] → Charla inteligente
!pensar → Te doy una idea brillante

🎨 **CREACIÓN DE IMÁGENES**
!imagen [tema] → Dibujo arte único
!dibujo [estilo] → Diseños especiales
!sticker → Convertir tu foto en sticker

🎵🎬 **DESCARGAS**
!mp3 [canción/artista] → Bajar música en alta calidad
!video [nombre/enlace] → Descargar videos de YouTube
!apk [nombre de app/juego] → Busco y te paso la aplicación

💡 **DATOS • JUEGOS • FRASES**
!dato → Curiosidades de la vida
!frase → Mis frases legendarias
!jugada → Una estrategia maestra
!adivinanza → Poné a prueba tu mente

🇦🇷 Hecho 100% en Argentina 🇦🇷`;

bot.on('message', async msg => {
    let txt = msg.body.toLowerCase().trim();

    if(['hola','bachira','menu','ayuda','comandos'].includes(txt)) return msg.reply(MENU);
    if(txt === 'creador') return msg.reply('💡 Todo esto fue desarrollado por **Benjare**, aquí en Argentina 🇦🇷 ¡gracias a él existo!');
    if(txt === 'frase') return msg.reply('❝ *Jugar para divertirse es el único secreto para ser el mejor.* ❞ — Bachira ⚽🟡');
    if(txt === 'dato') return msg.reply(['💡 El cerebro humano genera suficiente electricidad para encender una bombilla pequeña','💡 Correr libera endorfinas que te hacen feliz','💡 Usamos solo el 10% de nuestra capacidad cerebral'][Math.floor(Math.random()*3)]);
    if(txt === 'jugada') return msg.reply('⚽ Jugada maestra: Juega con el corazón, el resto sale solo ✨ ¡Magia pura!');

    // ✅ INTELIGENCIA ARTIFICIAL / CHAT GPT
    if(txt.startsWith('!ia ') || txt.startsWith('!gpt ')){
        let pregunta = txt.slice(4);
        try {
            let res = await axios.get(`https://api.siputzx.my.id/api/ai/gpt4?text=${encodeURIComponent(pregunta)}`);
            msg.reply(`🧠 *Inteligencia Bachira*\n${res.data.result}\n\n🇦🇷 Argentina`);
        } catch { msg.reply('❌ Mi mente está viajando, intentá de nuevo en un momento.'); }
    }

    // ✅ GENERAR IMÁGENES
    if(txt.startsWith('!imagen ') || txt.startsWith('!dibujo ')){
        let tema = txt.slice(txt.includes('imagen') ? 8 : 7);
        msg.reply('🎨 Creando arte lleno de magia... esperame 🟡');
        try {
            let res = await axios.get(`https://api.siputzx.my.id/api/ai/dalle?prompt=${encodeURIComponent(tema)}`, { responseType: 'arraybuffer' });
            await bot.sendMessage(msg.from, Buffer.from(res.data), { mimetype:'image/png', caption: '✅ Arte creado por Bachira 🇦🇷' });
        } catch { msg.reply('❌ No pude pintar esa idea ahora.'); }
    }

    // ✅ DESCARGAR MÚSICA MP3
    if(txt.startsWith('!mp3 ')){
        let nombre = txt.slice(5);
        msg.reply('🎵 Buscando tu ritmo favorito... 🇦🇷');
        try {
            let buscar = await axios.get(`https://api.siputzx.my.id/api/ytsearch?q=${encodeURIComponent(nombre)}`);
            let id = buscar.data.result[0].videoId;
            let bajar = await axios.get(`https://api.siputzx.my.id/api/ytdl/mp3?url=https://youtu.be/${id}`, { responseType: 'arraybuffer' });
            await bot.sendMessage(msg.from, Buffer.from(bajar.data), { mimetype:'audio/mpeg', filename: `${nombre}.mp3` });
        } catch { msg.reply('❌ Ritmo no encontrado. Probá escribirlo diferente.'); }
    }

    // ✅ DESCARGAR VIDEOS
    if(txt.startsWith('!video ')){
        let nombre = txt.slice(7);
        msg.reply('🎬 Preparando tu video de alta calidad... 🇦🇷');
        try {
            let buscar = await axios.get(`https://api.siputzx.my.id/api/ytsearch?q=${encodeURIComponent(nombre)}`);
            let id = buscar.data.result[0].videoId;
            let bajar = await axios.get(`https://api.siputzx.my.id/api/ytdl/mp4?url=https://youtu.be/${id}&quality=720`, { responseType: 'arraybuffer' });
            await bot.sendMessage(msg.from, Buffer.from(bajar.data), { mimetype:'video/mp4', filename: `${nombre}.mp4` });
        } catch { msg.reply('❌ No encontré ese video.'); }
    }

    // ✅ BUSCAR Y DESCARGAR APK
    if(txt.startsWith('!apk ')){
        let app = txt.slice(5);
        msg.reply('📱 Buscando la aplicación... esperame 🇦🇷');
        try {
            let res = await axios.get(`https://api.siputzx.my.id/api/apk/search?q=${encodeURIComponent(app)}`);
            if(res.data && res.data.download){
                msg.reply(`✅ *${app}* encontrado!\n🔗 Descargalo aquí: ${res.data.download}\n⚠️ Instalación segura y rápida 🇦🇷`);
            } else { msg.reply('❌ No encontré esa aplicación.'); }
        } catch { msg.reply('❌ Error al buscar, intentá otro nombre.'); }
    }

    // ✅ CREAR STICKER
    if(txt === '!sticker' && msg.hasMedia){
        let archivo = await msg.downloadMedia();
        await bot.sendMessage(msg.from, archivo, { sendMediaAsSticker: true, stickerName: "Bachira", stickerAuthor: "Benjare 🇦🇷" });
    }
});

bot.initialize();
EOF

